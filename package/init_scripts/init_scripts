# SDK2 package definition for init scripts

# Set package-specific variables

PACKAGE_NAME=init_scripts

SRC_DIR=$PACKAGE_NAME
BUILD_DIR=$SRC_DIR

# Functions

unpack () {

    echo "Unpacking $PACKAGE_NAME into $SD"

    # Copy the autoconf script

    rm -rf $SD
    mkdir $SD

    cp ${FD}/preq_check.ac ${SD}/

}

build () {

    echo "Building $PACKAGE_NAME in $BD"

    # Build

    cd $BD

    autoconf -o preq_check preq_check.ac

    if [ $? -ne 0 ]; then
	echo "FAILED in autoconf for $PACKAGE_NAME"
	exit 1
    fi

}    

install () {

    echo "Installing $PACKAGE_NAME from $BD"

    # Copy init scripts

    cd $BD

    files_dir=${FD}/${PROFILE_ARCH}

    if [[ ! -d $files_dir ]]; then
       echo "Unable to determine which files directory to use"
       exit 1
    fi

    cp -av ${files_dir}/init.sh ${DEST_ROOT}/bin/${PROFILE_NAME}_init.sh
    cp -av ${files_dir}/init.csh ${DEST_ROOT}/bin/${PROFILE_NAME}_init.csh

    if [[ $SDK2_PLATFORM_NAME = 'Linux' ]]; then
        cp -av ${files_dir}/arch_check ${DEST_ROOT}/bin/${PROFILE_NAME}_arch_check
    	cp -av preq_check ${DEST_ROOT}/bin/${PROFILE_NAME}_preq_check
    fi

    # Create the version script

    version_string="${PROFILE_ARCH}-${PROFILE_RELEASE}"

    sed -e s/@VERSION_STRING@/${version_string}/g \
	${FD}/version > ${DEST_ROOT}/bin/${PROFILE_NAME}_version
    chmod a+x ${DEST_ROOT}/bin/${PROFILE_NAME}_version

}
